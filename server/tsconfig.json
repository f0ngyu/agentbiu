{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "lib": [
      "ES2022"
    ],
    "types": [
      "bun-types"
    ],
    "rootDir": "..",
    "outDir": "./dist"
  },
  "include": [
    "src/**/*.ts",
    "../shared/src/**/*.ts"
  ],
  "exclude": [
    "../shared/src/**/*.test.ts",
    "../shared/src/**/*.spec.ts"
  ]
}
